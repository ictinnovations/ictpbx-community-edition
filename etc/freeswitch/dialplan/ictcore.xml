<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE dialplan>
<!-- ictcore dialplan -->
<include>
  <!-- inbound calls / DID -->
  <context name="ictcore">
    <!-- Ring group static XML files (one per ring group) -->
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/ring_groups/*.xml"/>
    <!-- IVR menus written by IvrMenu::sync_fs_dialplan() -->
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/ivr_menus/*.xml"/>
    <!-- Voicemail boxes written by Voicemail::sync_fs_dialplan() -->
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/voicemails/*.xml"/>
    <!-- Time conditions written by TimeCondition::sync_fs_dialplan() -->
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/time_conditions/*.xml"/>
    <!-- Call queues written by CallQueue::sync_fs_dialplan() -->
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/call_queues/*.xml"/>
    <!-- Call flows written by CallFlow::sync_fs_dialplan() -->
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/call_flows/*.xml"/>
    <!-- Inbound routes written by InboundRoute::save() -->
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/public/*.xml"/>
    <!-- Reroute: when carrier sends SIP username instead of DID number -->
    <extension name="inbound_gateway_reroute" continue="false">
      <condition field="destination_number" expression="^[a-zA-Z]">
        <action application="transfer" data="${sip_to_user} XML ictcore"/>
      </condition>
    </extension>
    <!-- bridge direct extension-to-extension calls for registered WebRTC/SIP users -->
    <extension name="local_ext_bridge" continue="false">
      <condition field="destination_number" expression="^(\d{4,6})$">
        <action application="bridge" data="user/$1@${domain_name}"/>
        <action application="lua" data="/usr/ictcore/bin/freeswitch/application.lua 0 inbound success"/>
        <action application="hangup"/>
      </condition>
    </extension>
    <extension name="application_inbound">
      <condition field="destination_number" expression="^\+?(\d+)$">
        <action application="lua" data="/usr/ictcore/bin/freeswitch/application.lua 0 inbound success" />
        <action application="hangup"/>
      </condition>
    </extension>
    <extension name="application_inbound_to">
     <condition field="${sip_to_user}" expression="^\+?(\d+)$">
       <action application="set" data="destination_number=${sip_to_user}"/>
       <action application="lua" data="/usr/ictcore/bin/freeswitch/application.lua 0 inbound success" />
       <action application="hangup"/>
     </condition>
    </extension>
  </context>
  <!-- public context: receives inbound calls from registered gateways -->
  <context name="public">
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/public/*.xml"/>
    <!-- Fallback: transfer unmatched DIDs into ictcore for ICTCore Lua processing -->
    <extension name="public_fallback" continue="false">
      <condition field="destination_number" expression="^\+?(\d+)$">
        <action application="transfer" data="$1 XML ictcore"/>
      </condition>
    </extension>
  </context>
  <!-- handle failed outgoing calls -->
  <context name="ictcore_fail">
    <extension name="app_originate_fail">
      <condition field="${originate_disposition}" expression="^(.*)$">
        <action application="lua" data="/usr/ictcore/bin/freeswitch/spool_failed.lua ${spool_id} ${application_id} $1" />
        <action application="hangup"/>
      </condition>
    </extension>
  </context>
  <!-- external context for outgoing calls, one extension per perfix -->
  <context name="ictcore_gateway">
    <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/provider/*.xml"/>
    <extension name="catch_invalid">
      <condition field="destination_number" expression=".*">
        <action application="playback" data="sounds/invalid_extension.wav"/>
        <action application="hangup"/>
      </condition>
    </extension>
  </context>
  <!-- internal context for each user -->
  <X-PRE-PROCESS cmd="include" data="/usr/ictcore/etc/freeswitch/dialplan/user/*.xml"/>
</include>
