; ictcore.conf.example - reference template
;
; The live ictcore.conf is generated by the installer scripts
; (ictcore-install.sh / ictcore-ce-install.sh) which substitute
; install-time values for hosts and prompted passwords.
;
; This file documents every section ICTCore will read. Values shown
; here are PLACEHOLDERS - never copy this file to production unchanged.
; The live file is gitignored; treat it as host-specific config.

[company]
name    = 'ICTCore Framework'
email   = no-reply@example.com
phone   = 0000000000
address = ''

[website]
title  = 'ICTCore Framework'
host   = <public-host>
port   = 80
path   = /api/
url    = http://<public-host>/api
log    = error warning info flow
cookie = ictcore
cors   =

[provisioning]
host = <public-host>
port = 5060
wss  = 7443

[security]
hash_type    = RS256
token_expiry = 31104000
private_key  = /usr/ictcore/etc/ssh/ib_node
public_key   = /usr/ictcore/etc/ssh/ib_node.pub

[gatewayhub]
url      =
username =
password =

[node]
node_id = 1

[db]
host = localhost
port = 3306
user = ictfax
pass = <set-by-installer>
name = ictfax
type = mysql

[sendmail]
cli           = /usr/sbin/sendmail -bs
folder        = /var/spool/mail/ictcore
domain        = localhost
reply_account = default
type          = smtp
host          =
port          = 587
user          =
pass          =

[freeswitch]
user     = user
password = ClueCon
host     = 127.0.0.1
port     = 8021
fs_cli   = /var/log/freeswitch/freeswitch.log

[kannel]
host =
port =
user =
pass =

[site]
title  = 'ICTPBX'
footer = 'Developed by ICTCore Team'
email  = no-reply@example.com

[domain]
title = ''

[edition]
; mode = community  ; uncomment + set to 'community' on CE installs

[fusionpbx]
host = 127.0.0.1
port = 5432
name = fusionpbx
user = fusionpbx
pass = <set-by-installer>
